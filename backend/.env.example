# Server Configuration
PORT=5000
JWT_SECRET=your_super_secret_jwt_key_here

# Database Configuration
# Replace with your local MongoDB URI or MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/campuslaunch?retryWrites=true&w=majority

# Optional API Keys (Leave as placeholders for basic demo)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GOOGLE_CALENDAR_CLIENT_ID=YOUR_GOOGLE_CALENDAR_CLIENT_ID
JITSI_MEET_APP_ID=YOUR_JITSI_MEET_APP_ID
FIREBASE_SERVER_KEY=YOUR_FIREBASE_SERVER_KEY
SENDGRID_API_KEY=YOUR_SENDGRID_API_KEY

# Automated Email Communication System (Resend)
# Sign up free at resend.com (3,000 emails/month, no credit card)
# API key starts with "re_"
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=onboarding@resend.dev
EMAIL_FROM_NAME=CampusLaunch
FRONTEND_URL=http://localhost:5173
TEST_EMAIL_RECIPIENT=your_test_email@gmail.com
